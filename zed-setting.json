// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "provider": "zed",
  },
  "auto_update_extensions": {
    "oxlint": false,
  },
  "ssh_connections": [
    {
      "host": "10.2.0.59",
      "username": "effort",
      "args": [],
      "projects": [
        {
          "paths": ["/home/effort"],
        },
        {
          "paths": ["/home/effort/work/chalibaocuser"],
        },
      ],
    },
  ],
  "diagnostics": {
    "lsp_pull_diagnostics": {
      "enabled": true,
    },
  },
  "disable_ai": true,
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll.eslint": true,
  },
  "autosave": "off",
  "ui_font_family": "Maple Mono NF CN",
  "icon_theme": "Catppuccin Mocha",
  "terminal": {
    "font_size": 14.0,
    "font_family": "Hack Nerd Font",
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never",
  },
  "cursor_blink": false,
  "buffer_font_fallbacks": [
    "JetBrains Mono",
    "CodeNewRoman Nerd Font",
    "JetBrains Mono Light",
    "Fira Mono",
    "Consolas",
    "Inconsolata Medium",
    "Dank Mono",
    "Monaco",
    "Courier New",
    "monospace",
    "Fira Code",
  ],
  "buffer_font_family": "Maple Mono NF CN",
  "file_types": {
    "javascript": ["*.wxs"],
    "vue": ["*.vue"],
    "jsonc": ["*.cjson"],
    "css": ["*.wxss"],
  },
  "tab_size": 2,
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Maple Light",
    "dark": "Maple Dark",
  },
  "proxy": "http://127.0.0.1:7890",

  // 配置信息
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "show_diagnostics": "errors",
  },

  // 文件扫描时要排除的文件和目录模式
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],

  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "notification_panel": {
    "dock": "left",
  },
}
