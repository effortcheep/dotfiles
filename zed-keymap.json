  //     "ctrl-c": "editor::Copy",
  //     "ctrl-v": "editor::Paste",
  //     "ctrl-f": "search::FocusSearch",
  //     // "ctrl-w": ["pane::CloseActiveItem", { "close_pinned": false }]
